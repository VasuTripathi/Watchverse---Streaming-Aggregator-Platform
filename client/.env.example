# Watchverse Client Environment Configuration
# Copy this file to .env.local and fill in your actual values

# API Configuration
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_API_TIMEOUT=30000

# Environment
REACT_APP_ENV=development

# Feature Flags
REACT_APP_ENABLE_AI_CHAT=true
REACT_APP_ENABLE_WATCHLIST=true
REACT_APP_ENABLE_RECOMMENDATIONS=true

# Analytics (optional)
# REACT_APP_GA_ID=UA-XXXXXXXXX-X

# External APIs
# REACT_APP_TMDB_API_KEY=your-tmdb-api-key
# REACT_APP_OMDB_API_KEY=your-omdb-api-key

# Deployment URL (for production)
# REACT_APP_DOMAIN=https://watchverse.com
